# Telegram Bot 配置
TG_BOT_TOKEN=your_bot_token_here
TG_ADMIN_UID=your_telegram_id_here

# NodeSeek 论坛配置
NODESEEK_COOKIES=your_cookies_here
NODESEEK_ADMIN_UID=your_nodeseek_uid_here

# Webhook 配置
WEBHOOK_URL=https://your-domain.com
PORT=8080
HOST=0.0.0.0

# 数据存储
DATA_FILE=/var/lib/tg-nodeseek-bot/data.json

# 轮询设置 (秒)
POLL_INTERVAL=30

# 验证设置
VERIFICATION_TTL=2592000
CODE_LENGTH=6
