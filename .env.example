# Telegram Bot 配置
TG_BOT_TOKEN=your_bot_token_here
TG_ADMIN_UID=your_telegram_id_here

# NodeSeek 论坛配置
NODESEEK_COOKIES=your_cookies_here

# DeepFlood 论坛配置（可选，留空则不启用）
# DEEPFLOOD_COOKIES=your_deepflood_cookies_here

# Webhook 配置
WEBHOOK_URL=https://your-domain.com
PORT=8080
HOST=0.0.0.0

# 轮询设置 (秒)
POLL_INTERVAL=30
RSS_POLL_INTERVAL=60

# RSS 配置
RSS_URL=https://rss.nodeseek.com
RSS_HTTP_TIMEOUT=15
RSS_MAX_ENTRIES=50
RSS_DISABLE_WEB_PAGE_PREVIEW=true
RSS_HISTORY_LIMIT=200

# 代理设置（可选，留空则直连）
PROXY_HOST=
PROXY_PORT=0

# 日志等级（TRACE/DEBUG/INFO/SUCCESS/WARNING/ERROR/CRITICAL）
LOG_LEVEL=INFO

# 验证设置
VERIFICATION_TTL=2592000
CODE_LENGTH=6

# 抽奖 Webhook 认证密钥（与 lucky.user.js 中的 AUTH_KEY 一致）
LUCKY_AUTH_KEY=your_lucky_auth_key_here
